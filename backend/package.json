{
  "name": "lawcaseai-backend",
  "version": "1.0.0",
  "description": "Backend API for LawCaseAI LegalTech SaaS platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon -r tsconfig-paths/register src/server.ts",
    "dev:simple": "nodemon src/server-simple.ts",
    "dev:js": "nodemon src/server.js",
    "build": "tsc && tsc-alias",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "legaltech",
    "law",
    "saas",
    "api",
    "nodejs",
    "typescript"
  ],
  "author": "LawCaseAI Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@paddle/paddle-node-sdk": "^3.6.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.25.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.55.0"
  },
  "overrides": {
    "fast-xml-parser": "5.5.9",
    "brace-expansion": "^2.0.1",
    "minimatch": "^3.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
